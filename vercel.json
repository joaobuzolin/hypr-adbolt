{
  "rewrites": [
    {
      "source": "/templates/:path*",
      "destination": "/templates/:path*"
    },
    {
      "source": "/preview/:path*",
      "destination": "/preview/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
